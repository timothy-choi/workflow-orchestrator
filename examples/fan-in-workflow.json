  "steps": [
    {
      "name": "A",
      "image": "busybox:latest",
      "command": "echo branch-A",
      "dependencies": []
    },
    {
      "name": "B",
      "image": "busybox:latest",
      "command": "echo branch-B",
      "dependencies": []
    },
    {
      "name": "merge",
      "image": "busybox:latest",
      "command": "echo merged-after-A-and-B",
