{
  "title": "Workflow orchestrator",
  "uid": "workflow-orchestrator-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Executions created / succeeded / failed (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(workflow_executions_total[$__rate_interval]))", "legendFormat": "created", "refId": "A" },
        { "expr": "sum(rate(workflow_executions_succeeded_total[$__rate_interval]))", "legendFormat": "succeeded", "refId": "B" },
        { "expr": "sum(rate(workflow_executions_failed_total[$__rate_interval]))", "legendFormat": "failed", "refId": "C" },
        { "expr": "sum(rate(workflow_executions_cancelled_total[$__rate_interval]))", "legendFormat": "cancelled", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Running executions",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "workflow_executions_running", "legendFormat": "running", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Paused executions",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "workflow_executions_paused_current", "legendFormat": "paused", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Failed steps (current)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "workflow_steps_failed_current", "legendFormat": "failed", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Pending steps",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "workflow_steps_pending", "legendFormat": "pending", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Callbacks received (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(workflow_callbacks_received_total[$__rate_interval])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Kubernetes jobs created / deleted (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(workflow_kubernetes_jobs_total[$__rate_interval]))", "legendFormat": "created", "refId": "A" },
        { "expr": "sum(rate(workflow_kubernetes_jobs_deleted_total[$__rate_interval]))", "legendFormat": "deleted", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Execution duration (seconds, sum rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(workflow_execution_duration_seconds_sum[$__rate_interval])) / sum(rate(workflow_execution_duration_seconds_count[$__rate_interval]))", "legendFormat": "avg duration", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Step failures - terminal (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(workflow_steps_failed_total[$__rate_interval]))", "legendFormat": "terminal failures", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
